# Referaa — nginx example for 103.21.187.238
#
# Problem: if HTTPS has "auth_basic" (password protection), email verify links return
# 401 Unauthorized. Verification must be PUBLIC (no login).
#
# Copy/adapt into your server block, then: sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name 103.21.187.238;

    # Optional: keep HTTP for verify only; redirect everything else to HTTPS
    location = /api/auth/verify-email {
        proxy_pass http://127.0.0.1:5001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /verify-email {
        return 302 /api/auth/verify-email?$args;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:5001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        root /var/www/referaa/frontend;
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 443 ssl;
    server_name 103.21.187.238;

    # ssl_certificate ...;
    # ssl_certificate_key ...;

    # === MUST BE PUBLIC (no auth_basic here) ===
    location = /api/auth/verify-email {
        auth_basic off;
        proxy_pass http://127.0.0.1:5001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /verify-email {
        auth_basic off;
        return 302 /api/auth/verify-email?$args;
    }

    location /api/ {
        auth_basic off;
        proxy_pass http://127.0.0.1:5001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Frontend SPA — if you use password protection, keep it only here (not on /api/auth/verify-email)
    location / {
        # auth_basic "Referaa";
        # auth_basic_user_file /etc/nginx/.htpasswd;
        root /var/www/referaa/frontend;
        try_files $uri $uri/ /index.html;
    }
}
