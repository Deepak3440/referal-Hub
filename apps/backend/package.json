{
  "name": "@referaa/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && node --env-file=../../.env --enable-source-maps ./dist/index.mjs",
    "build": "node ./build.mjs",
    "start": "node --env-file=../../.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed:demo": "tsx --env-file=../../.env src/scripts/seed-demo-users.ts",
    "seed:demo-referrals": "tsx --env-file=../../.env src/scripts/seed-demo-referrals.ts"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "thread-stream": "3.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "tsx": "catalog:"
  }
}
