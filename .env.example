# =============================================================================
# Referaa — copy to .env and update secrets (MONGO_URI, JWT_SECRET)
# =============================================================================


# -----------------------------------------------------------------------------
# 1) REQUIRED
# -----------------------------------------------------------------------------

MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/referral_hub
JWT_SECRET=change-this-to-a-long-random-secret-in-production


# -----------------------------------------------------------------------------
# 2) SERVER
# -----------------------------------------------------------------------------

PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Public URL for email verification links (usually same host as frontend if /api is proxied)
API_PUBLIC_URL=http://localhost:5173
# Base URL for links inside verification emails (use http:// if https has password protection)
VERIFY_EMAIL_BASE_URL=http://localhost:5173
VERIFY_EMAIL_LINK_HTTP=true


# -----------------------------------------------------------------------------
# 2b) EMAIL VERIFICATION (signup)
# -----------------------------------------------------------------------------
# Set EMAIL_VERIFICATION_ENABLED=false to skip verification in local dev.
# Without SMTP, the backend logs the verification link in the terminal.

EMAIL_VERIFICATION_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Referaa <noreply@referaa.com>


# -----------------------------------------------------------------------------
# 3) NEW USER POINTS
# -----------------------------------------------------------------------------

INITIAL_USER_POINTS=200


# -----------------------------------------------------------------------------
# 4) REFERRAL REWARDS (% of job rewardPoints)
# -----------------------------------------------------------------------------
# Example: 300 pt job → send −30, accept −30, referred −90, hired −150 (total −300)

REWARDS_POINTS_ENABLED=true

REWARDS_REQUEST_DEDUCT_PCT=10
REWARDS_REQUEST_CREDIT_PCT=10
REWARDS_ACCEPT_DEDUCT_PCT=10
REWARDS_ACCEPT_CREDIT_PCT=20
REWARDS_REFERRED_DEDUCT_PCT=30
REWARDS_REFERRED_CREDIT_PCT=30
REWARDS_HIRED_DEDUCT_PCT=50
REWARDS_HIRED_CREDIT_PCT=50


# -----------------------------------------------------------------------------
# 5) BUY POINTS — Profile page (simulated payment; real gateway later)
# -----------------------------------------------------------------------------

POINTS_PURCHASE_ENABLED=true

# Default 3 packs: Starter 100 | Growth 575 (+15%) | Pro 2600 (+30% on 2k)
# Bigger pack = higher bonusPercent. Remove this line to use code defaults.
POINTS_PURCHASE_PACKAGES=[{"id":"starter","label":"Starter","points":100,"priceInr":99,"bonusPercent":0},{"id":"growth","label":"Growth","points":500,"priceInr":399,"bonusPercent":15,"popular":true},{"id":"pro","label":"Pro","points":2000,"priceInr":1299,"bonusPercent":30}]


# -----------------------------------------------------------------------------
# 6) MENTORSHIP — slots, points payment, Jitsi video (Topmate-style)
# -----------------------------------------------------------------------------
# See docs/MENTORSHIP-SETUP.md for full flow.

MENTORSHIP_PAYMENT_ENABLED=true

# Optional: extra admin user IDs (comma-separated). Seeded admin@referaa.com works without this.
# ADMIN_USER_IDS=

# Jitsi Meet (default public instance — no API keys required)
# Room URL: https://{JITSI_DOMAIN}/referaa-session-{consultationId}
JITSI_DOMAIN=meet.jit.si
